# ============================================
# BusConnect Backend - Environment Variables
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA subas el archivo .env a Git
#
# IMPORTANTE: Estos valores son para Docker.
# Si ejecutas servicios sin Docker, usa localhost:5432
# ============================================

# PostgreSQL Database
POSTGRES_DB=busconnectdb
POSTGRES_USER=busconnect_user
POSTGRES_PASSWORD=your_secure_password_here  # Cambia por tu contraseña real