# ============================================
# BusConnect Backend - Environment Variables
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus valores reales
# 3. NUNCA subas el archivo .env a Git
#
# IMPORTANTE: Estos valores son para Docker.
# Si ejecutas servicios sin Docker, usa localhost:5432
# ============================================

# PostgreSQL Database
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=your_database_name

# Database Connection (for microservices)
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_password_here
DB_HOST=postgres
DB_PORT=5432